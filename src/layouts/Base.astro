---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = "Vatted — The Whisky Index for Global Investors", description = "Vatted tracks premium cask indices across Scotch, Bourbon, and Japanese whisky — accessible via crypto or fiat, for any investor worldwide." } = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Vatted",
      "description": "The world's first fractionalized whisky index platform — giving global investors diversified exposure to premium whisky casks through both crypto and traditional fiat rails.",
      "url": "https://whisky-fractions-index.onrender.com"
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col font-body antialiased" style="background: oklch(0.09 0.020 42); color: oklch(0.85 0.030 80);">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
