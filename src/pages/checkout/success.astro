---
import Base from '../../layouts/Base.astro';
---
<Base title="Payment Successful — Your New Business">
  <section class="py-20 md:py-28">
    <div class="max-w-lg mx-auto px-4 sm:px-6 text-center">
      <div class="mx-auto w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mb-6">
        <svg class="w-8 h-8 text-green-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
        </svg>
      </div>
      <h1 class="text-3xl font-bold text-surface-900 font-display">Payment Successful!</h1>
      <p class="mt-4 text-lg text-surface-800/60 leading-relaxed">
        Thank you for your purchase. You should receive a confirmation email shortly.
      </p>
      <a href="/" class="mt-8 inline-block px-6 py-3 bg-brand-500 text-white font-semibold rounded-lg hover:bg-brand-600 transition-colors">
        Back to Home
      </a>
    </div>
  </section>
</Base>
