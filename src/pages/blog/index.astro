---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => (b.data.pubDate?.valueOf() ?? 0) - (a.data.pubDate?.valueOf() ?? 0)
);
---
<Base title="Blog">
  <section class="py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-surface-900 font-display mb-10">Blog</h1>
      {posts.length === 0 && (
        <p class="text-surface-800/50">No posts yet — check back soon.</p>
      )}
      <ul class="space-y-8">
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.id}`} class="group block">
              <h2 class="text-xl font-semibold text-surface-900 group-hover:text-brand-500 transition-colors">
                {post.data.title}
              </h2>
              {post.data.description && (
                <p class="mt-2 text-surface-800/60 leading-relaxed">{post.data.description}</p>
              )}
              {post.data.pubDate && (
                <time class="mt-2 block text-sm text-surface-800/40">
                  {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              )}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Base>
